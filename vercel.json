{
  "version": 2,
  "name": "flipkart-sample44-frontend",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/(.*)$", "dest": "/$1" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://your-render-service.onrender.com/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://your-render-service.onrender.com/uploads/$1" },
    { "source": "/(.*\\.php.*)", "destination": "https://your-render-service.onrender.com/$1" }
  ],
  "cleanUrls": true
}
